<style>
  .message-content{
    font-family: Arial, Helvetica, sans-serif;
    max-width: 600px;
    font-size: 18px;
    line-height: 21px;
  }
</style>

<div class="message-content">
  <p>Olá, {{name}}</p>
  <h3>Relatórios.</h3>

  <h4>Quantidades de ligações por cidade</h4>
  {{#each cities}}
    {{>city city=.}}
  {{/each}}

  <h4>Quantidades de ligações por bairro</h4>
  {{#each neighborhoods}}
    {{>neighborhood neighborhood=.}}
  {{/each}}

    <h4>Quantidades de ligações por plano</h4>
  {{#each plans}}
    {{>plan plan=.}}
  {{/each}}

</div>
